{
  "name": "jetbit-exchange-funding-engine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "yarn run link && node engine/app.js",
    "deploy": "yarn run link && node_modules/.bin/sequelize db:migrate && yarn insert:asset-statuses && node app/server.js",
    "dev": "yarn run link && nodemon --require engine/sentry/instrument.js engine/funding-fee/v2/index.js",
    "start-cluster": "npm run link && ./node_modules/.bin/pm2 start ecosystem.config.js",
    "test:funding-fee": "PORT=8080 NODE_ENV=test nyc --all --check-coverage --reporter=text-summary mocha --recursive engine/funding-fee/**/*.test.js --timeout 2500000 --exit",
    "link": "cd node_modules && ln -nsf ../engine",
    "eslint": "./node_modules/.bin/eslint --max-warnings 0 ."
  },
  "dependencies": {
    "@sentry/node": "^8.51.0",
    "@sentry/profiling-node": "^8.51.0",
    "axios": "^1.1.3",
    "bignumber.js": "^9.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mysql2": "^2.3.3",
    "nodemon": "^3.1.9",
    "pm2": "^5.2.2",
    "sequelize": "^6.25.5",
    "sequelize-cli": "^6.5.2",
    "socket.io": "^4.5.3",
    "sqlite3": "^5.1.2",
    "uuid": "^9.0.0",
    "yargs": "^17.6.2"
  },
  "devDependencies": {
    "chai": "^4.3.7",
    "eslint": "^8.27.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "mocha": "^10.1.0",
    "mockdate": "^3.0.5",
    "nyc": "^15.1.0",
    "prettier": "2.7.1",
    "supertest": "^6.3.1"
  },
  "applink": {
    "app": ""
  },
  "nyc": {
    "include": [
      "engine/**/*.js"
    ],
    "statements": 80,
    "functions": 80,
    "branches": 70,
    "lines": 80,
    "exclude": []
  },
  "optionalDependencies": {
    "fsevents": "^2.3.2"
  }
}
